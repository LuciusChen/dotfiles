#!/bin/sh
set -eu

# WeChat Universal is an X11/Qt application.  Launching its binary directly
# skips the HiDPI and input-method environment supplied by its wrapper.
# Keep the existing unsandboxed profile/data paths while restoring those
# compatibility settings.
export QT_QPA_PLATFORM=xcb
export QT_AUTO_SCREEN_SCALE_FACTOR=1
export QT_IM_MODULE=fcitx
export GTK_IM_MODULE=fcitx
export XMODIFIERS=@im=fcitx

exec /opt/wechat-universal/wechat "$@"
