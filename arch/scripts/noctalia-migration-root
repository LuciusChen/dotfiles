#!/usr/bin/env bash
set -euo pipefail

if [[ ${EUID} -ne 0 ]]; then
  echo "error: run this script with sudo" >&2
  exit 1
fi

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
arch_dir=$(cd -- "${script_dir}/.." && pwd)
greetd_source="${arch_dir}/etc/greetd/config.toml"
greeter_setup=/usr/share/noctalia-greeter/setup_greeter_system.sh

activate() {
  [[ -x ${greeter_setup} ]] || {
    echo "error: ${greeter_setup} is missing; install noctalia-greeter-git" >&2
    exit 1
  }
  [[ -f ${greetd_source} ]] || {
    echo "error: ${greetd_source} is missing" >&2
    exit 1
  }

  backup_dir=/var/backups/noctalia-migration
  install -d -m 0700 "${backup_dir}"
  if [[ -f /etc/greetd/config.toml ]]; then
    timestamp=$(date +%Y%m%d%H%M%S)
    cp -a /etc/greetd/config.toml "${backup_dir}/config.toml.${timestamp}"
  fi

  # The packaged --print-greeter-user helper currently writes debug output to
  # stdout. Pin the account so command substitution cannot absorb that log.
  GREETER_USER=greeter "${greeter_setup}"
  install -Dm0644 "${greetd_source}" /etc/greetd/config.toml

  # Change the next graphical boot only. Keep the current Ly/Hyprland session alive.
  systemctl disable ly@tty2.service
  systemctl enable accounts-daemon.service greetd.service

  echo
  echo "Noctalia migration activated for the next boot."
  systemctl is-enabled ly@tty2.service greetd.service accounts-daemon.service || true
}

rollback() {
  # Change the next graphical boot only; do not disturb the current session.
  systemctl disable greetd.service
  systemctl enable ly@tty2.service

  echo
  echo "Ly rollback activated for the next boot."
  systemctl is-enabled ly@tty2.service greetd.service || true
}

case "${1:-}" in
  activate)
    activate
    ;;
  rollback)
    rollback
    ;;
  *)
    echo "usage: $0 {activate|rollback}" >&2
    exit 2
    ;;
esac
