#!/usr/bin/env bash
# pkgcache - manage pacman cached package versions with tagging support
# Usage: pkgcache [command] [args]

set -euo pipefail

CACHE_DIR="${PKGCACHE_DIR:-/var/cache/pacman/pkg}"
TAG_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/pkgcache/tags.json"
mkdir -p "$(dirname "$TAG_FILE")"
[[ -f "$TAG_FILE" ]] || echo '{}' > "$TAG_FILE"

# ── helpers ──────────────────────────────────────────────────────────────────

die()  { echo "error: $*" >&2; exit 1; }
info() { echo ":: $*"; }

# parse "name-ver-rel-arch.pkg.tar.*" → pkgname, version (ver-rel)
parse_pkg() {
    local file="$1"
    local base="${file##*/}"
    base="${base%.pkg.tar.*}"
    # arch is last field, rel is second-to-last, split from right
    local arch="${base##*-}"
    base="${base%-$arch}"
    local rel="${base##*-}"
    base="${base%-$rel}"
    local ver="${base##*-}"
    local name="${base%-$ver}"
    echo "$name" "$ver-$rel" "$arch"
}

# list all .pkg.tar.* files (no .sig)
list_pkgs() {
    find "$CACHE_DIR" -maxdepth 1 -name '*.pkg.tar.*' ! -name '*.sig' -printf '%f\n' 2>/dev/null | sort
}

# get installed version of a package (empty if not installed)
installed_ver() {
    pacman -Q "$1" 2>/dev/null | awk '{print $2}' || true
}

# json tag helpers (requires python3, avoids jq dependency)
tag_get() { python3 -c "
import json,sys
d=json.load(open('$TAG_FILE'))
print(d.get('$1',{}).get('$2',''))
"; }

tag_set() { python3 -c "
import json,sys
path='$TAG_FILE'
d=json.load(open(path))
d.setdefault('$1',{})['$2']='$3'
json.dump(d,open(path,'w'),indent=2)
"; }

tag_del() { python3 -c "
import json
path='$TAG_FILE'
d=json.load(open(path))
if '$1' in d and '$2' in d['$1']:
    del d['$1']['$2']
    if not d['$1']: del d['$1']
json.dump(d,open(path,'w'),indent=2)
"; }

tag_list_pkg() { python3 -c "
import json
d=json.load(open('$TAG_FILE'))
for ver,tag in d.get('$1',{}).items():
    print(ver,tag)
"; }

# ── commands ─────────────────────────────────────────────────────────────────

cmd_list() {
    local filter="${1:-}"
    local prev_name=""
    declare -A versions

    while IFS= read -r f; do
        read -r name ver arch <<< "$(parse_pkg "$f")"
        [[ -n "$filter" && "$name" != *"$filter"* ]] && continue
        versions["$name"]+="$ver "
    done < <(list_pkgs)

    for name in $(echo "${!versions[@]}" | tr ' ' '\n' | sort); do
        local vers="${versions[$name]}"
        local count; count=$(wc -w <<< "$vers")
        (( count < 2 )) && continue  # only show packages with old versions

        local cur; cur=$(installed_ver "$name")
        printf "\n\033[1;36m%s\033[0m" "$name"
        [[ -n "$cur" ]] && printf "  \033[2m(installed: %s)\033[0m" "$cur"
        echo

        for ver in $(echo "$vers" | tr ' ' '\n' | sort -V); do
            local tag; tag=$(tag_get "$name" "$ver")
            local marker="  "
            local col="\033[0m"
            [[ "$ver" == "$cur" ]] && marker="\033[1;32m* \033[0m" && col="\033[1;32m"
            [[ -n "$tag"         ]] && col="\033[1;33m"
            printf "  ${marker}${col}%-40s\033[0m" "$ver"
            [[ -n "$tag" ]] && printf "  \033[33m[%s]\033[0m" "$tag"
            echo
        done
    done
}

cmd_list_all() {
    # like list but show single-version packages too
    local filter="${1:-}"
    declare -A versions

    while IFS= read -r f; do
        read -r name ver arch <<< "$(parse_pkg "$f")"
        [[ -n "$filter" && "$name" != *"$filter"* ]] && continue
        versions["$name"]+="$ver "
    done < <(list_pkgs)

    for name in $(echo "${!versions[@]}" | tr ' ' '\n' | sort); do
        local cur; cur=$(installed_ver "$name")
        printf "\033[1;36m%s\033[0m" "$name"
        [[ -n "$cur" ]] && printf "  \033[2m(installed: %s)\033[0m" "$cur"
        echo
        for ver in $(echo "${versions[$name]}" | tr ' ' '\n' | sort -V); do
            local tag; tag=$(tag_get "$name" "$ver")
            local marker="  "
            local col="\033[0m"
            [[ "$ver" == "$cur" ]] && marker="\033[1;32m* \033[0m" && col="\033[1;32m"
            [[ -n "$tag"         ]] && col="\033[1;33m"
            printf "  ${marker}${col}%-40s\033[0m" "$ver"
            [[ -n "$tag" ]] && printf "  \033[33m[%s]\033[0m" "$tag"
            echo
        done
    done
}

cmd_tag() {
    local pkg="${1:-}"; local ver="${2:-}"; local label="${3:-good}"
    [[ -z "$pkg" || -z "$ver" ]] && die "usage: pkgcache tag <package> <version> [label]"
    # verify it exists in cache
    local found=0
    while IFS= read -r f; do
        read -r n v _ <<< "$(parse_pkg "$f")"
        [[ "$n" == "$pkg" && "$v" == "$ver" ]] && found=1 && break
    done < <(list_pkgs)
    (( found )) || die "package $pkg $ver not found in cache"
    tag_set "$pkg" "$ver" "$label"
    info "tagged $pkg $ver as [$label]"
}

cmd_untag() {
    local pkg="${1:-}"; local ver="${2:-}"
    [[ -z "$pkg" || -z "$ver" ]] && die "usage: pkgcache untag <package> <version>"
    tag_del "$pkg" "$ver"
    info "removed tag from $pkg $ver"
}

cmd_tags() {
    local pkg="${1:-}"
    if [[ -n "$pkg" ]]; then
        tag_list_pkg "$pkg" | while read -r ver label; do
            printf "  \033[1;33m%-40s\033[0m  [%s]\n" "$ver" "$label"
        done
        return
    fi
    python3 -c "
import json
d=json.load(open('$TAG_FILE'))
for pkg,vers in sorted(d.items()):
    print(f'\033[1;36m{pkg}\033[0m')
    for ver,tag in sorted(vers.items()):
        print(f'  \033[1;33m{ver:<40}\033[0m  [{tag}]')
"
}

cmd_downgrade() {
    local pkg="${1:-}"; local ver="${2:-}"
    [[ -z "$pkg" ]] && die "usage: pkgcache downgrade <package> [version]"

    # collect versions for this package
    declare -a found_vers found_files
    while IFS= read -r f; do
        read -r n v _ <<< "$(parse_pkg "$f")"
        if [[ "$n" == "$pkg" ]]; then
            found_vers+=("$v")
            found_files+=("$CACHE_DIR/$f")
        fi
    done < <(list_pkgs)

    (( ${#found_vers[@]} )) || die "no cached versions found for $pkg"

    if [[ -z "$ver" ]]; then
        echo "Cached versions of $pkg:"
        for i in "${!found_vers[@]}"; do
            local tag; tag=$(tag_get "$pkg" "${found_vers[$i]}")
            printf "  %2d) %-40s" "$((i+1))" "${found_vers[$i]}"
            [[ -n "$tag" ]] && printf "  \033[33m[%s]\033[0m" "$tag"
            echo
        done
        printf "Select version [1-%d]: " "${#found_vers[@]}"
        read -r choice
        local idx=$(( choice - 1 ))
        ver="${found_vers[$idx]}"
        local pkg_file="${found_files[$idx]}"
    else
        local pkg_file=""
        for i in "${!found_vers[@]}"; do
            [[ "${found_vers[$i]}" == "$ver" ]] && pkg_file="${found_files[$i]}" && break
        done
        [[ -z "$pkg_file" ]] && die "$pkg $ver not found in cache"
    fi

    info "downgrading $pkg to $ver"
    sudo pacman -U "$pkg_file"
}

cmd_help() {
    cat <<'EOF'
pkgcache - pacman cache manager with version tagging

COMMANDS
  list    [filter]              list packages with multiple cached versions
  list-all [filter]             list all cached packages
  tag     <pkg> <ver> [label]   tag a version (default label: good)
  untag   <pkg> <ver>           remove tag
  tags    [pkg]                 show all tags (or for one package)
  downgrade <pkg> [ver]         install a cached version via pacman -U

EXAMPLES
  pkgcache list                 # show all packages with old caches
  pkgcache list firefox         # filter by name
  pkgcache tag linux 6.12.1-1 stable
  pkgcache tags                 # show everything tagged
  pkgcache downgrade linux      # interactive downgrade

ENVIRONMENT
  PKGCACHE_DIR   override cache directory (default: /var/cache/pacman/pkg)

TAG FILE
  ~/.local/share/pkgcache/tags.json
EOF
}

# ── dispatch ─────────────────────────────────────────────────────────────────

case "${1:-help}" in
    list)      cmd_list     "${2:-}" ;;
    list-all)  cmd_list_all "${2:-}" ;;
    tag)       cmd_tag      "${2:-}" "${3:-}" "${4:-good}" ;;
    untag)     cmd_untag    "${2:-}" "${3:-}" ;;
    tags)      cmd_tags     "${2:-}" ;;
    downgrade) cmd_downgrade "${2:-}" "${3:-}" ;;
    help|--help|-h) cmd_help ;;
    *) die "unknown command '$1'. Run: pkgcache help" ;;
esac
