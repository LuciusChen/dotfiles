#!/bin/sh
set -eu

firefox_bin=/usr/lib/firefox/firefox
focus_helper="$HOME/.local/libexec/labwc/wlrctl"

# Firefox forwards the URL to an existing browser process. Under Wayland that
# hand-off can lose the activation token, so explicitly activate the Firefox
# toplevel after handing over the URL.
"$firefox_bin" "$@" >/dev/null 2>&1 &

if [ ! -x "$focus_helper" ]; then
  exit 0
fi

attempt=0
while [ "$attempt" -lt 50 ]; do
  if [ -n "$("$focus_helper" window list app_id:firefox 2>/dev/null)" ]; then
    "$focus_helper" window focus app_id:firefox 2>/dev/null || true
    exit 0
  fi
  attempt=$((attempt + 1))
  sleep 0.1
done

exit 0
