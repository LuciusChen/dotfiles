#!/bin/sh

# Integrate portals and other graphical user services with this session.
systemctl --user --no-block start labwc-session.target

# Apply the matching laptop/docked display profile.
kanshi >/dev/null 2>&1 &

# Noctalia owns the bar, launcher, notifications, clipboard, lock and idle UI.
noctalia --daemon

# Session applications preserved from the Hyprland setup.
fcitx5 -d -r
~/.dropbox-dist/dropboxd >/dev/null 2>&1 &

# Keep the existing GTK appearance.
gsettings set org.gnome.desktop.interface gtk-theme "catppuccin-mocha-green-standard+default"
gsettings set org.gnome.desktop.interface icon-theme "Papirus-Dark"
gsettings set org.gnome.desktop.interface color-scheme "prefer-dark"
